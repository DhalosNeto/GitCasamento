rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Families / Guests ---
    match /families/{familyId} {
      // Allow reading individual family for RSVP (ID or code)
      allow get: if true;
      // Full access only for Admin (Authenticated via custom backend/server SDK)
      // The Node.js Express backend uses Admin SDK which bypasses these rules naturally.
      // Therefore, the frontend clients CANNOT write directly to Firestore bypassing our Express server validations.
      allow write: if false;
      // These rules are for client-side SDK access (which we don't use often, but for safety):
      allow list, create, delete: if false; 
    }

    // --- Gifts ---
    match /gifts/{giftId} {
      // Anyone can see the gift list
      allow read: if true;
      // Only the Admin (via API) can manage gifts
      allow write: if false;
    }
  }
}
